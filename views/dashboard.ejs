<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Dashboard</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        display: flex;
        height: 100vh;
        background: linear-gradient(135deg, #1e1e2f, #3a3a5f);
        color: #fff;
      }

      /* Sidebar */
      .sidebar {
        width: 240px;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        padding: 20px;
        display: flex;
        flex-direction: column;
      }

      .sidebar h2 {
        text-align: center;
        margin-bottom: 30px;
        color: #ffcc00;
      }

      .sidebar a {
        text-decoration: none;
        color: #ccc;
        padding: 12px;
        margin: 5px 0;
        border-radius: 8px;
        transition: 0.3s;
      }

      .sidebar a:hover {
        background: #ff0066;
        color: #fff;
      }

      /* Main */
      .main {
        flex: 1;
        padding: 20px;
      }

      /* Navbar */
      .navbar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .navbar h1 {
        font-size: 24px;
      }

      .navbar button {
        padding: 10px 15px;
        border: none;
        border-radius: 8px;
        background: #ff0066;
        color: #fff;
        cursor: pointer;
      }

      /* Cards */
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
      }

      .card {
        padding: 20px;
        border-radius: 15px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
        transition: 0.3s;
      }

      .card:hover {
        transform: translateY(-5px);
      }

      .card h3 {
        margin-bottom: 10px;
        color: #ffcc00;
      }

      .card p {
        font-size: 20px;
        font-weight: bold;
      }

      /* Table */
      table {
        width: 100%;
        margin-top: 30px;
        border-collapse: collapse;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        overflow: hidden;
      }

      table th,
      table td {
        padding: 12px;
        text-align: left;
      }

      table th {
        background: #ff0066;
      }

      table tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.05);
      }
    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <div class="sidebar">
      <h2>MyApp</h2>
      <a href="#">Dashboard</a>
      <a href="#">Profile</a>
      <a href="#">Settings</a>
      <a href="/">Logout</a>
    </div>

    <!-- Main Content -->
    <div class="main">
      <!-- Navbar -->
      <div class="navbar">
        <h1>Welcome, User 👋</h1>
        <button>Logout</button>
      </div>

      <!-- Cards -->
      <div class="cards">
        <div class="card">
          <h3>Total Users</h3>
          <p>1,245</p>
        </div>

        <div class="card">
          <h3>Active Users</h3>
          <p>845</p>
        </div>

        <div class="card">
          <h3>New Signups</h3>
          <p>120</p>
        </div>

        <div class="card">
          <h3>Revenue</h3>
          <p>$5,230</p>
        </div>
      </div>

      <!-- Table -->
      <table>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Phone</th>
        </tr>
        <tr>
          <td>nikhil</td>
          <td>nikhil@gmail.com</td>
          <td>9876543210</td>
        </tr>
        <tr>
          <td>rahul</td>
          <td>rahul@gmail.com</td>
          <td>9999999999</td>
        </tr>
      </table>
    </div>
  </body>
</html>
