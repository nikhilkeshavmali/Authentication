<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Signup Form</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #181733, #3b3724, #00ccff);
        background-size: 300% 300%;
        animation: gradientMove 6s infinite alternate;
      }

      @keyframes gradientMove {
        0% {
          background-position: left;
        }
        100% {
          background-position: right;
        }
      }

      .container {
        width: 350px;
        padding: 40px;
        border-radius: 20px;
        backdrop-filter: blur(20px);
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        color: #fff;
        text-align: center;
      }

      h2 {
        margin-bottom: 20px;
      }

      .input-box {
        position: relative;
        margin: 25px 0;
      }

      input {
        width: 100%;
        padding: 12px;
        border: none;
        outline: none;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        font-size: 16px;
      }

      label {
        position: absolute;
        top: 50%;
        left: 12px;
        transform: translateY(-50%);
        color: #ddd;
        font-size: 14px;
        transition: 0.3s;
        pointer-events: none;
      }

      input:focus + label,
      input:valid + label {
        top: -8px;
        left: 10px;
        font-size: 12px;
        background: #ff0066;
        padding: 2px 8px;
        border-radius: 5px;
        color: #fff;
      }

      .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(45deg, #2b1d22, #7b6f43);
        color: #fff;
        font-size: 16px;
        cursor: pointer;
      }

      .btn:hover {
        transform: scale(1.05);
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h2>Create Account</h2>

      <form action="/signup" method="POST">
        <!-- Username -->
        <div class="input-box">
          <input type="text" id="username" name="username" required />
          <label for="username">Username</label>
        </div>

        <!-- Email -->
        <div class="input-box">
          <input type="email" id="useremail" name="useremail" required />
          <label for="useremail">Email</label>
        </div>

        <!-- Password -->
        <div class="input-box">
          <input type="password" id="password" name="password" required />
          <label for="password">Password</label>
        </div>

        <!-- Phone -->
        <div class="input-box">
          <input type="tel" id="phone" name="phone" required />
          <label for="phone">Phone</label>
        </div>

        <button type="submit" class="btn">Sign Up</button>
        <div class="footer">Don't have an account? <a href="/">Sign Up</a></div>
      </form>
    </div>
  </body>
</html>
